{
  "compilerOptions": {
    /* File Layout */
    "rootDir": "./src",
    "outDir": "./dist",
    
    /* Environment Settings */
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ESNext",
    "lib": ["ESNext"],
    "types": ["node", "express", "cors"], // <--- Agregamos express y cors aquí

    /* Other Outputs */
    "sourceMap": true,
    "declaration": true,

    /* Ajustes para evitar fallos en Render */
    "strict": false,                 // <--- Cambiado a false para que sea más permisivo
    "noImplicitAny": false,          // <--- IMPORTANTE: Esto silencia los errores de req/res
    "esModuleInterop": true,
    "skipLibCheck": true,            // <--- Evita errores en librerías de terceros
    "forceConsistentCasingInFileNames": true,
    "moduleDetection": "force"
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}