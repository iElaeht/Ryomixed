{
  "compilerOptions": {
    /* File Layout */
    "rootDir": "./src",          // Indica dónde está tu código TS
    "outDir": "./dist",         // Indica dónde se guardará el código JS compilado
    
    /* Environment Settings */
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ESNext",
    "lib": ["ESNext"],
    "types": ["node"],

    /* Other Outputs */
    "sourceMap": true,
    "declaration": true,

    /* Recommended Options */
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleDetection": "force"
  },
  "include": ["src/**/*"],      // Obligatorio para que compile toda la carpeta src
  "exclude": ["node_modules"]
}